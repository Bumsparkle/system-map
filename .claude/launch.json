{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@system-map/web", "dev"],
      "port": 5173
    },
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@system-map/api", "start"],
      "port": 3001
    },
    {
      "name": "web-demo",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@system-map/web", "preview", "--port", "4173", "--strictPort"],
      "port": 4173
    },
    {
      "name": "web-sub",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "VITE_BASE=/system-map/ pnpm --filter @system-map/web preview --port 4174 --strictPort"
      ],
      "port": 4174
    },
    {
      "name": "web-demo-dev",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "VITE_DEMO=1 pnpm --filter @system-map/web dev --port 5174 --strictPort"
      ],
      "port": 5174
    },
    {
      "name": "web-auth-dev",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "VITE_SUPABASE_URL=https://example.supabase.co VITE_SUPABASE_ANON_KEY=dummy-anon-key pnpm --filter @system-map/web dev --port 5175 --strictPort"
      ],
      "port": 5175
    }
  ]
}
