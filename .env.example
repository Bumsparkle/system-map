# Postgres connection (matches docker-compose.yml)
DATABASE_URL=postgres://systemmap:systemmap@localhost:5432/systemmap

# API server
API_PORT=3001

# Web -> API base URL (leave unset in prod; the web app uses the same origin)
VITE_API_URL=http://localhost:3001

# logo.dev publishable token for vendor logos (optional; nodes fall back to icons)
# LOGO_DEV_TOKEN=pk_xxx
# Serve logo.dev URLs directly instead of mirroring to disk (set to 1 on serverless)
# LOGO_DEV_DIRECT=1

# Supabase Auth (production). When both are set the API requires a bearer JWT and
# the web app shows a login screen. Leave unset for local single-user no-auth dev.
# See DEPLOY.md for where each value comes from.
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_ANON_KEY=<anon-key>
# VITE_SUPABASE_URL=https://<ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon-key>
# Owner id assigned to seeded data (your Supabase user id when seeding prod)
# DEV_USER_ID=
